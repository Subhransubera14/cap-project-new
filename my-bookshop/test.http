### Filter: Exact string match
# GET http://localhost:4004/catalog/Books?$filter=genre eq 'Fantasy'

# ### Filter: Number comparison
# GET http://localhost:4004/catalog/Books?$filter=price gt 10

# ### Filter: Boolean
# GET http://localhost:4004/catalog/Books?$filter=stock gt 0

# ### Filter: Date comparison
# GET http://localhost:4004/catalog/Books?$filter=publishDate gt 1990-01-01

# ### Filter: String contains (case-sensitive)
# GET http://localhost:4004/catalog/Books?$filter=contains(title,'Potter')

# ### Filter: String contains (case-insensitive)
# GET http://localhost:4004/catalog/Books?$filter=contains(tolower(title),'potter')

# ### Filter: Starts with
# GET http://localhost:4004/catalog/Authors?$filter=startswith(name,'J')

# ### Filter: Combined with AND
# GET http://localhost:4004/catalog/Books?$filter=price gt 10 and rating ge 4.5

# ### Filter: Combined with OR
# GET http://localhost:4004/catalog/Books?$filter=genre eq 'Fantasy' or genre eq 'Mystery'

# ### Filter: Complex with parentheses
# GET http://localhost:4004/catalog/Books?$filter=(genre eq 'Fantasy' or genre eq 'Fiction') and price lt 15

# ### Filter: Null check
# GET http://localhost:4004/catalog/Books?$filter=isbn ne null







