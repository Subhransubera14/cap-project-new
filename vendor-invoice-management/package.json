{
  "name": "vendor-invoice-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cds-serve",
    "watch-invoice-ui": "cds watch --open com.vendor.invoice.management.invoiceui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-approver-ui": "cds watch --open approverui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy Vendor-Invoice-Management --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-analytics-ui": "cds watch --open analyticsui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-analyticsui": "cds watch --open analyticsui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-vendor-manager-ui": "cds watch --open com.vendor.invoice.management.vendormanagerui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-viewer-ui": "cds watch --open com.vendor.invoice.management.viewerui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "alice": {
            "password": "alice",
            "roles": [
              "Admin"
            ]
          },
          "manager1": {
            "password": "manager1",
            "roles": [
              "VendorManager"
            ]
          },
          "approver1": {
            "password": "approver1",
            "roles": [
              "Approver"
            ]
          },
          "viewer1": {
            "password": "viewer1",
            "roles": [
              "Viewer"
            ]
          }
        }
      },
      "API_BUSINESS_PARTNER": {
        "kind": "odata-v2",
        "model": "srv/external/API_BUSINESS_PARTNER",
        "credentials": {
          "destination": "s4hana"
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        },
        "db": "hana"
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/invoice-ui",
    "app/approver-ui",
    "app/analyticsui",
    "app/analytics-ui",
    "app/vendor-manager-ui",
    "app/vendor-manager-ui",
    "app/viewer-ui"
  ]
}
